{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "runtimeArgs": ["--env-file=.env"],
      "args": ["src/server.ts"],
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Start Services",
      "console": "integratedTerminal",
      "restart": true
    },
    {
      "name": "Dev Server (no services)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "runtimeArgs": ["--env-file=.env"],
      "args": ["src/server.ts"],
      "skipFiles": ["<node_internals>/**"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "restart": true
    }
  ]
}
