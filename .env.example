# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/recruitment

# Session encryption secret (min 32 chars, generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-32-char-string

# HMAC secret for teacher links (generate with: openssl rand -hex 32)
HMAC_SECRET=change-me-to-another-random-secret

# Resend API key for email sending (production)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email sender address (must be verified in Resend)
EMAIL_FROM=noreply@yourdomain.com

# Local dev: Mailcatcher SMTP (started via `npm run services:up`)
# View emails at http://localhost:1080 — remove these lines in production
SMTP_HOST=localhost
SMTP_PORT=1025

# App URL (no trailing slash)
APP_URL=http://localhost:3000

# Optional: custom port
PORT=3000
